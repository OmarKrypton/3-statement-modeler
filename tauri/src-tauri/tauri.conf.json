{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "3-Statement Modeler",
  "version": "1.0.0",
  "identifier": "com.omar.3smodeler",
  "build": {
    "frontendDist": "http://localhost:8000",
    "devUrl": "http://localhost:8000"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/3sm"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "3-Statement Modeler",
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": false,
        "url": "http://localhost:8000",
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
